---
import { profile, socials } from "../data/site";
import Icon from "./Icon.astro";
---

<section id="contact" class="scroll-mt-24 py-20 sm:py-28">
  <div class="container-px">
    <div class="card-surface reveal relative overflow-hidden px-6 py-16 text-center sm:px-12 sm:py-20">
      <div
        class="pointer-events-none absolute -bottom-32 left-1/2 h-72 w-[40rem] -translate-x-1/2 rounded-full bg-brand-gradient opacity-20 blur-[100px]"
        aria-hidden="true"
      >
      </div>

      <p class="eyebrow justify-center flex">05 — Contact</p>
      <h2 class="mx-auto mt-4 max-w-2xl font-display text-3xl font-bold tracking-tight sm:text-4xl">
        Let's build something <span class="text-gradient">together</span>.
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-white/60">
        Open to software development roles and collaborations. The fastest way to
        reach me is by email.
      </p>

      {
        profile.email && (
          <a
            href={`mailto:${profile.email}`}
            class="group mt-8 inline-flex items-center gap-2 rounded-full bg-white px-7 py-3.5 text-sm font-medium text-ink-950 transition-transform hover:-translate-y-0.5"
          >
            <Icon name="email" class="h-4 w-4" />
            {profile.email}
          </a>
        )
      }

      <ul class="mt-10 flex items-center justify-center gap-3">
        {
          socials.map((s) => (
            <li>
              <a
                href={s.href}
                target={s.icon === "email" ? undefined : "_blank"}
                rel="noopener noreferrer"
                aria-label={s.label}
                class="flex h-11 w-11 items-center justify-center rounded-full border border-white/10 text-white/70 transition-all hover:-translate-y-0.5 hover:border-white/30 hover:text-white"
              >
                <Icon name={s.icon} class="h-[18px] w-[18px]" />
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
