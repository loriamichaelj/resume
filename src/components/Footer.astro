---
import { profile, nav } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 py-10">
  <div class="container-px flex flex-col items-center justify-between gap-6 sm:flex-row">
    <p class="text-sm text-white/45">
      © {year} {profile.name}. All rights reserved.
    </p>

    <ul class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-sm text-white/50 transition-colors hover:text-white"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <p class="font-mono text-xs text-white/30">Built with Astro</p>
  </div>
</footer>
