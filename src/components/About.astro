---
import { profile, certifications } from "../data/site";
import SectionHeading from "./SectionHeading.astro";

const stats = [
  { value: "AZ-900", label: "Microsoft Azure Certified" },
  { value: "B.S.", label: "Computer Science · CSULA" },
];
---

<section id="about" class="scroll-mt-24 py-20 sm:py-28">
  <div class="container-px grid gap-12 lg:grid-cols-[1fr_1.1fr] lg:gap-16">
    <SectionHeading eyebrow="01 — About" title="A bit about me" />

    <div>
      <p class="reveal text-lg leading-relaxed text-white/70" data-delay="80">
        {profile.bio}
      </p>

      <dl class="reveal mt-10 grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-white/10 bg-white/5 sm:grid-cols-2" data-delay="160">
        {
          stats.map((s) => (
            <div class="bg-ink-900/60 p-6">
              <dt class="font-display text-2xl font-bold text-gradient">{s.value}</dt>
              <dd class="mt-1 text-sm text-white/55">{s.label}</dd>
            </div>
          ))
        }
      </dl>

      <div class="reveal mt-6" data-delay="200">
        <p class="eyebrow mb-3">Certifications</p>
        <ul class="flex flex-col gap-2.5">
          {
            certifications.map((c) => (
              <li class="card-surface flex items-center gap-4 px-5 py-3.5">
                <span class="font-mono text-sm font-medium text-gradient">{c.code}</span>
                <span class="text-sm text-white/80">{c.name}</span>
                <span class="ml-auto text-xs text-white/45">{c.status}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
